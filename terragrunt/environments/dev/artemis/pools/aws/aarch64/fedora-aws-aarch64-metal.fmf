# AWS aarch64 metal instances pool

default-flavor: m7g.metal
flavor-regex: ^(c6g|c6gd|c7g|c7gd|c7gn|m6g|m6gd|m7g|m7gd|r6g|r6gd|r7g|r7gd|c8g|c8gd|m8g)\.metal.*$

custom-flavors:
    # Graviton2 instances
    - name: c6g.metal-100
      base: c6g.metal
      disk:
          - size: "100 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

    - name: c6g.metal-250
      base: c6g.metal
      disk:
          - size: "250 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

