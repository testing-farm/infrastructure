      disk:
          - size: "500 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

    # Cascade Lake instances
    - name: m5.metal-100
      base: m5.metal
      disk:
          - size: "100 GiB"
          - additional-disks:
