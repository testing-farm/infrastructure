patch-flavors:
    - name-regex: '(c5n|z1d)\..+'
      cpu:
          family: 6
          family-name: Skylake
          model: 85
          model-name: Intel(R) Xeon(R) Platinum 8124M CPU @ 3.00GHz
          flag:
              - fpu
              - vme
              - de
              - pse
              - tsc
              - msr
              - pae
              - mce
              - cx8
              - apic
              - sep
              - mtrr
              - pge
              - mca
              - cmov
