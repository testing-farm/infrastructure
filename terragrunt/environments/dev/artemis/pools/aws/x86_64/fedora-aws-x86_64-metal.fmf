# AWS x86_64 metal instances pool

flavor-regex: ^(c5|c5d|c5n|c7i|m5|m5zn|m7i|z1d)\.metal.*$

custom-flavors:
    # Cascade Lake instances
    - name: c5.metal-100
      base: c5.metal
      disk:
          - size: "100 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

    - name: c5.metal-250
      base: c5.metal
      disk:
          - size: "250 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

    - name: c5.metal-500
      base: c5.metal
      disk:
          - size: "500 GiB"
          - additional-disks:
                max-count: 5
                min-size: "10 GiB"
                max-size: "512 GiB"

    - name: c5d.metal-100
