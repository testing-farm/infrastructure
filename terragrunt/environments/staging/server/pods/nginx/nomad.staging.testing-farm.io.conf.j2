server {
    listen 80;
    server_name  nomad.staging{{ staging_ci_suffix | default("") }}.testing-farm.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name  nomad.staging{{ staging_ci_suffix | default("") }}.testing-farm.io;

    ssl_certificate /etc/ssl/nginx/fullchain.pem;
    ssl_certificate_key /etc/ssl/nginx/privkey.pem;

    location / {
        # https://developer.hashicorp.com/nomad/tutorials/manage-clusters/reverse-proxy-ui
        proxy_pass http://127.0.0.1:4646;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 310s;
        proxy_buffering off;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Origin "${scheme}://${proxy_host}";

{% for ip in nomad.additional_ips.split() %}
        allow {{ ip }};
{% endfor %}
        deny all;
    }
}
