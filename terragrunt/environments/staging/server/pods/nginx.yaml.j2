apiVersion: v1
kind: Pod
metadata:
  annotations:
    bind-mount-options: /etc/nginx/conf.d:Z,/etc/ssl/nginx:Z
  labels:
    app: nginx
  name: nginx
spec:
  containers:
    - name: nginx
      image: quay.io/testing-farm/nginx:latest
      args:
        - nginx
        - -g
        - daemon off;
      volumeMounts:
        - name: nginx
          mountPath: /etc/nginx/conf.d/
        - name: artifacts
          mountPath: /var/artifacts
        - name: ssl-certs
          mountPath: /etc/ssl/nginx/
          readOnly: true
  hostNetwork: true
  volumes:
    - name: nginx
      hostPath:
        path: /etc/nginx/conf.d
        type: Directory
    - name: artifacts
      hostPath:
        path: /var/data/artifacts
        type: Directory
    - name: ssl-certs
      hostPath:
        path: /etc/ssl/nginx
        type: Directory
