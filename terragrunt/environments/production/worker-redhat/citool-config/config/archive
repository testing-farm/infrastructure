[default]
artifacts-rsync-host = artifacts.osci.redhat.com/artifacts/testing-farm
# NOTE: required, but unused for daemon mode
artifacts-root = /archive
source-destination-map = ${config_root}/source-destination-map.yaml
archive-mode = daemon
# --exclude=plans/**/tree/ drops the tmt test checkouts (cloned test source, not
# results) from the upload. They dominate the file count - thousands of tiny files
# per test variant - and drive the NFS metadata load and inode pressure on the host.
rsync-options = --links,--times,--verbose,--compress,--checksum,--exclude=plans/**/tree/
enable-parallel-archiving = yes
rsync-timeout = 600
