#!/bin/bash

{#

We use {[]} for templating in the file because the default {{}}
collides with formatting option of podman

#}

if [ "$DEBUG" != "" ]; then
  set -x
fi

if [ "$USER" != "root" ]; then
    echo "This script has to be run as root!"
    exit 1
fi

CITOOL_IMAGE="${CITOOL_IMAGE:-citool:latest}"
CITOOL_CONFIG_DIR="${CITOOL_CONFIG_DIR:-/etc/citool.d}"
CITOOL_RUN_DIR="${CITOOL_RUN_DIR:-$PWD}"
CITOOL_OPTIONS=()
CITOOL_PIPELINE=("$@")

# Mount docker config for registry authentication if available
DOCKER_CONFIG_MOUNT=""
if [ -f /root/.docker/config.json ]; then
  DOCKER_CONFIG_MOUNT="-v /root/.docker/config.json:/root/.docker/config.json:ro,Z"
fi

# If a config image is specified, create a volume from the citool-config container
# and mount it at /CONFIG instead of the host directory.
CONFIG_MOUNT="-v ${CITOOL_CONFIG_DIR}:/CONFIG:O"
if [ -n "$CITOOL_CONFIG_IMAGE" ]; then
  CONFIG_VOLUME="citool-config-${REQUEST_ID:-$$}"
  podman volume create "$CONFIG_VOLUME"
  if ! podman run --rm --pull=newer -v "$CONFIG_VOLUME":/worker "$CITOOL_CONFIG_IMAGE"; then
      echo "ERROR: Failed to pull/run config image: $CITOOL_CONFIG_IMAGE"
      podman volume rm "$CONFIG_VOLUME" 2>/dev/null || true
      exit 1
  fi

  # Copy environment.yaml into the volume if it exists on the host, replacing the placeholder from the config image.
  if [ -f "${CITOOL_CONFIG_DIR}/environment.yaml" ]; then
    mount_path=$(podman volume mount "$CONFIG_VOLUME") || { echo "ERROR: Failed to mount volume $CONFIG_VOLUME"; exit 1; }
    cp "${CITOOL_CONFIG_DIR}/environment.yaml" "${mount_path}/{[ deployment ]}/citool-config/environment.yaml"
    podman volume unmount "$CONFIG_VOLUME"
  fi

  CONFIG_MOUNT="-v ${CONFIG_VOLUME}:/CONFIG:O
                {%- for s in citool_config_podman_secrets | default([]) %}
                --secret {[ s.name ]},target={[ s.target ]}{%- if s.mode is defined %},mode={[ s.mode ]}{%- endif %}
                {%- endfor %}"
  CITOOL_OPTIONS=(--debug-file citool-debug.txt --verbose-file citool-debug.verbose.txt
                  --module-config-path "/CONFIG/{[ deployment ]}/citool-config/config,/CONFIG/common/citool-config/config,/CONFIG-SECRETS/config")
fi

echo "Known images:"
podman images

echo
image_id=`podman inspect -f '{{.Id}}' $CITOOL_IMAGE`
ctime=`podman inspect -f '{{.Created}}' $CITOOL_IMAGE`
echo "Image is $image_id, created on $ctime"

echo

# export image details into environmnet, so it gets to Sentry
export CITOOL_IMAGE
export CITOOL_IMAGE_ID="$image_id"
export CITOOL_IMAGE_CTIME="$ctime"
export SENTRY_TAG_MAP="citool_image=${CITOOL_IMAGE},citool_image_id=${CITOOL_IMAGE_ID},hostname=$(hostname),ip=$(curl ipv4.icanhazip.com),request_id=${REQUEST_ID},artifacts_url=${ARTIFACTS_URL}/${REQUEST_ID}"

# --init is required to collect zombies processes
# --rm is required to cleanup the container after it has been run
# --privileged is required to run container based workloads
#
# Mount /CONFIG with overlay. See TFT-3927 for details.
#
# /CONFIG and /ARTIFACTS are the default mounts of the upstream citoool container
exec podman run --init \
                --rm \
                --privileged \
                --network=host \
                --name ${REQUEST_ID:-no-request-$RANDOM} \
                ${CONFIG_MOUNT} \
                -v ${CITOOL_RUN_DIR}:/var/ARTIFACTS:Z \
                -v /root/.ssh:/root/.ssh:Z \
                -e SENTRY_DSN={[ sentry_dsn ]} \
                -e SENTRY_BASE_URL={[ sentry_base_url ]} \
                -e SENTRY_ENVIRONMENT={[ deployment ]} \
                -e SENTRY_RELEASE={[ release ]} \
                -e SENTRY_TAG_MAP=${SENTRY_TAG_MAP} \
                ${CITOOL_EXTRA_PODMAN_ARGS} \
                ${DOCKER_CONFIG_MOUNT} \
                "$CITOOL_IMAGE" "${CITOOL_OPTIONS[@]}" "${CITOOL_PIPELINE[@]}"
